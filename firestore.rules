rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. ADMIN KURALI: 
    // Bu UID'ye sahip olan kişi HER ŞEYİ okuyabilir ve yazabilir.
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == "8qmKa6jVWLQevRpla9o00khN4tT2";
    }

    // YARDIMCI FONKSİYONLAR
    function isSignedIn() {
      return request.auth != null;
    }

    function isNotBanned() {
      // exists() kontrolü yeni kullanıcıların dökümanı oluşana kadar hata almasını önler
      let publicDocPath = /databases/$(database)/documents/users_public/$(request.auth.uid);
      return !exists(publicDocPath) || (
        (!('isBanned' in get(publicDocPath).data) || get(publicDocPath).data.isBanned == false) &&
        (!('report_count' in get(publicDocPath).data) || get(publicDocPath).data.report_count < 10)
      );
    }

    // 2. NORMAL KULLANICI KURALLARI:

    match /users_private/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /users_public/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId && isNotBanned();
    }

    match /friendships/{friendshipId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.users;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.users && isNotBanned();
      allow update, delete: if isSignedIn() && request.auth.uid in resource.data.users && isNotBanned();
    }

    match /reports/{reportId} {
      allow create: if isSignedIn();
    }

    // İstatistikler: Herkes görebilmeli (list için), sadece sahibi yazabilir
    match /learned_words/{docId} {
      allow read: if isSignedIn(); 
      allow write: if isSignedIn() && (resource == null || resource.data.user_id == request.auth.uid) && isNotBanned();
    }
    
    match /quiz_results/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (resource == null || resource.data.user_id == request.auth.uid) && isNotBanned();
    }
    
    match /user_progress/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (resource == null || resource.data.user_id == request.auth.uid) && isNotBanned();
    }

    match /weak_words/{docId} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.user_id == request.auth.uid) && isNotBanned();
    }

    match /chats/{chatId} {
      allow read, write: if isSignedIn() && isNotBanned();
      
      match /{allPaths=**} {
        allow read, write: if isSignedIn() && isNotBanned();
      }
    }
  }
}
