rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. ADMIN KURALI
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == "8qmKa6jVWLQevRpla9o00khN4tT2";
    }

    // YARDIMCI FONKSİYONLAR
    function isSignedIn() {
      return request.auth != null;
    }

    function isNotBanned() {
      // exists() ile döküman olup olmadığını kontrol et
      let path = /databases/$(database)/documents/users_public/$(request.auth.uid);
      if (!exists(path)) {
        return true; 
      }
      let data = get(path).data;
      return (data.get('isBanned', false) == false) && (data.get('report_count', 0) < 10);
    }

    // 2. NORMAL KULLANICI KURALLARI

    // Eski koleksiyon (Yalnızca göç için gerekli)
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
    }

    match /users_private/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /users_public/{userId} {
      allow read: if isSignedIn();
      // create: Yeni kayıt her zaman serbest
      allow create: if isSignedIn() && request.auth.uid == userId;
      // update: Sadece banlanmamışsa
      allow update: if isSignedIn() && request.auth.uid == userId && isNotBanned();
    }

    match /friendships/{friendshipId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.users;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.users && isNotBanned();
      allow update, delete: if isSignedIn() && request.auth.uid in resource.data.users && isNotBanned();
    }

    match /reports/{reportId} {
      allow create: if isSignedIn();
    }

    // İstatistikler (Listeleme ve okuma serbest, yazma sadece sahibi ve banlanmamışsa)
    match /learned_words/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (resource == null || resource.data.user_id == request.auth.uid) && isNotBanned();
    }
    
    match /quiz_results/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (resource == null || resource.data.user_id == request.auth.uid) && isNotBanned();
    }
    
    match /user_progress/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (resource == null || resource.data.user_id == request.auth.uid) && isNotBanned();
    }

    match /weak_words/{docId} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.user_id == request.auth.uid) && isNotBanned();
    }

    match /chats/{chatId} {
      allow read, write: if isSignedIn() && isNotBanned();
      match /{allPaths=**} {
        allow read, write: if isSignedIn() && isNotBanned();
      }
    }
  }
}
